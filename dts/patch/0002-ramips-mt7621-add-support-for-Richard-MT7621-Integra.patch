From 08c096fc229479dfab6cdbbf5132c9d53be4b2f1 Mon Sep 17 00:00:00 2001
From: Richard Tung <dyq@dyq.me>
Date: Sun, 1 Mar 2026 16:33:44 +0800
Subject: [PATCH 2/2] ramips: mt7621: add support for Richard MT7621 Integrated
 Router

Hardware:
- SoC: Mediatek MT7621AT
- Flash: 32 MB
- RAM: 256 MB
- Ethernet: 3x 10/100/1000 Mbps, built into the SoC
- WLAN: 2x Mini PCI-E (PCIe x1)
- WWAN: 1x NGFF B Key 3042/3052 (USB 3.0/Optional PCIe x1)
- USB: 1x USB 2.0 (XH2.54 4P)
- Buttons: 1 Reset button, 1x Car ACC (BTN_0),
  1x Power (Triggered via MCU)
- LEDs: 3x Green for Ethernet, 3x Orange (Customizable),
  2x Green for Power (Router/DC Output), 1x Green (MCU RUN)
- FAN: 1x 5V FAN
- DC Output: 1x VH3.96 2P + 1x XH2.54 2P (Controlled by MCU)
- Power: 9-16 VDC, 3A, barrel plug or VH3.96 3P
- Power Management: GD32E230F8P6 MCU
---
 .../dts/mt7621_richard_mt7621-ig-router.dts   | 206 ++++++++++++++++++
 target/linux/ramips/image/mt7621.mk           |  10 +
 .../mt7621/base-files/etc/board.d/01_leds     |   5 +
 .../mt7621/base-files/etc/board.d/02_network  |   3 +
 4 files changed, 224 insertions(+)
 create mode 100644 target/linux/ramips/dts/mt7621_richard_mt7621-ig-router.dts

diff --git a/target/linux/ramips/dts/mt7621_richard_mt7621-ig-router.dts b/target/linux/ramips/dts/mt7621_richard_mt7621-ig-router.dts
new file mode 100644
index 0000000000..32ea686104
--- /dev/null
+++ b/target/linux/ramips/dts/mt7621_richard_mt7621-ig-router.dts
@@ -0,0 +1,206 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+// Copyright 2026 Richard Tung <dyq@dyq.me>
+
+#include "mt7621.dtsi"
+
+#include <dt-bindings/gpio/gpio.h>
+#include <dt-bindings/input/input.h>
+#include <dt-bindings/thermal/thermal.h>
+
+/ {
+	compatible = "richard,mt7621-ig-router", "hilink,hlk-7621a-evb", "mediatek,mt7621-soc";
+	model = "Richard's MT7621 Integrated Router";
+
+	keys {
+		compatible = "gpio-keys";
+
+		reset {
+			label = "reset";
+			gpios = <&gpio 18 GPIO_ACTIVE_HIGH>;
+			linux,code = <KEY_RESTART>;
+		};
+
+		car_acc {
+			label = "car_acc";
+			gpios = <&gpio 16 GPIO_ACTIVE_LOW>;
+			linux,code = <BTN_0>;
+		};
+
+		power {
+			label = "power";
+			gpios = <&gpio 17 GPIO_ACTIVE_HIGH>;
+			linux,code = <KEY_POWER>;
+		};
+	};
+
+	aliases {
+		led-boot = &led_orange_wan;
+		led-failsafe = &led_orange_wan;
+		led-running = &led_orange_wan;
+		led-upgrade = &led_orange_wan;
+	};
+
+	leds {
+		compatible = "gpio-leds";
+
+		led_orange_lan1: orange_lan1 {
+			label = "orange:lan1";
+			gpios = <&gpio 13 GPIO_ACTIVE_LOW>;
+		};
+
+		led_orange_lan2: orange_lan2 {
+			label = "orange:lan2";
+			gpios = <&gpio 14 GPIO_ACTIVE_LOW>;
+		};
+
+		led_orange_wan: orange_wan {
+			label = "orange:wan";
+			gpios = <&gpio 15 GPIO_ACTIVE_LOW>;
+		};
+	};
+
+	gpio_wdt: gpio-wdt {
+		compatible = "linux,wdt-gpio";
+		gpios = <&gpio 7 GPIO_ACTIVE_LOW>;
+		hw_algo = "toggle";
+		hw_margin_ms = <1000>;
+		always-running;
+	};
+
+	gpio-export {
+
+		compatible = "gpio-export";
+		#size-cells = <0>;
+
+		wwan-pwr {
+			gpio-export,name = "wwan_pwr";
+			gpio-export,output = <1>;
+			gpios = <&gpio 0 GPIO_ACTIVE_HIGH>;
+		};
+
+		fan-pwr {
+			gpio-export,name = "fan_pwr";
+			gpio-export,output = <1>;
+			gpios = <&gpio 6 GPIO_ACTIVE_HIGH>;
+		};
+	};
+};
+
+&spi0 {
+	status = "okay";
+
+	flash@0 {
+		compatible = "jedec,spi-nor";
+		reg = <0>;
+		spi-max-frequency = <44000000>;
+		broken-flash-reset;
+
+		partitions {
+			compatible = "fixed-partitions";
+			#address-cells = <1>;
+			#size-cells = <1>;
+
+			partition@0 {
+				label = "u-boot";
+				reg = <0x0 0x30000>;
+				read-only;
+			};
+
+			partition@30000 {
+				label = "u-boot-env";
+				reg = <0x30000 0x10000>;
+				read-only;
+			};
+
+			partition@40000 {
+				label = "factory";
+				reg = <0x40000 0x10000>;
+				read-only;
+
+				nvmem-layout {
+					compatible = "fixed-layout";
+					#address-cells = <1>;
+					#size-cells = <1>;
+
+					macaddr_factory_e000: macaddr@e000 {
+						reg = <0xe000 0x6>;
+					};
+
+					macaddr_factory_e006: macaddr@e006 {
+						reg = <0xe006 0x6>;
+					};
+				};
+			};
+
+			partition@50000 {
+				compatible = "denx,uimage";
+				label = "firmware";
+				reg = <0x50000 0x1fb0000>;
+			};
+		};
+	};
+};
+
+&gmac0 {
+	nvmem-cells = <&macaddr_factory_e000>;
+	nvmem-cell-names = "mac-address";
+};
+
+&gmac1 {
+	status = "okay";
+	label = "wan";
+	phy-handle = <&ethphy4>;
+
+	nvmem-cells = <&macaddr_factory_e006>;
+	nvmem-cell-names = "mac-address";
+};
+
+&ethphy4 {
+	/delete-property/ interrupts;
+};
+
+&switch0 {
+	ports {
+		port@1 {
+			status = "okay";
+			label = "lan1";
+		};
+
+		port@2 {
+			status = "okay";
+			label = "lan2";
+		};
+	};
+};
+
+&pcie {
+	status = "okay";
+};
+
+&i2c {
+	status = "okay";
+
+	aht20@38 {
+		compatible = "aosong,aht20";
+		reg = <0x38>;
+		status = "okay";
+	};
+
+	ina226@40 {
+		compatible = "ti,ina226";
+		reg = <0x40>;
+		status = "okay";
+		shunt-resistor = <10000>;
+	};
+};
+
+&uartlite2 {
+	status = "okay";
+};
+
+&state_default {
+	gpio {
+		groups = "wdt", "jtag", "uart3";
+		function = "gpio";
+	};
+};
diff --git a/target/linux/ramips/image/mt7621.mk b/target/linux/ramips/image/mt7621.mk
index f6a05db8d3..ec97ace6fa 100644
--- a/target/linux/ramips/image/mt7621.mk
+++ b/target/linux/ramips/image/mt7621.mk
@@ -3574,3 +3574,13 @@ define Device/zyxel_wsm20
   KERNEL_INITRAMFS := kernel-bin | lzma | fit lzma $$(KDIR)/image-$$(firstword $$(DEVICE_DTS)).dtb | znet-header V1.00(ABZF.0)C0
 endef
 TARGET_DEVICES += zyxel_wsm20
+
+define Device/richard_mt7621-ig-router
+  $(Device/dsa-migration)
+  $(Device/uimage-lzma-loader)
+  DEVICE_VENDOR := Richard
+  DEVICE_MODEL := MT7621 Integrated Router
+  DEVICE_PACKAGES += kmod-usb3 kmod-hwmon-core kmod-hwmon-ina2xx kmod-hwmon-ath10 -uboot-envtools
+  IMAGE_SIZE := 32448k
+endef
+TARGET_DEVICES += richard_mt7621-ig-router
diff --git a/target/linux/ramips/mt7621/base-files/etc/board.d/01_leds b/target/linux/ramips/mt7621/base-files/etc/board.d/01_leds
index 5d92006d66..66494f1fc8 100644
--- a/target/linux/ramips/mt7621/base-files/etc/board.d/01_leds
+++ b/target/linux/ramips/mt7621/base-files/etc/board.d/01_leds
@@ -197,6 +197,11 @@ oraybox,x3a)
 	ucidef_set_led_netdev "wan" "wan link" "red:status" "wan"
 	ucidef_set_led_netdev "lan" "lan link" "green:status" "br-lan"
 	;;
+richard,mt7621-ig-router)
+	ucidef_set_led_netdev "wifi2g" "WiFi 2.4GHz" "orange:lan1" "wlan0"
+	ucidef_set_led_netdev "wifi5g" "WiFi 5GHz" "orange:lan2" "wlan1"
+	ucidef_set_led_netdev "wwan0" "WWAN" "orange:wan" "wwan0" "link tx rx"
+	;;
 snr,snr-cpe-me1)
 	ucidef_set_led_usbport "usb" "USB" "green:usb" "usb1-port1" "usb2-port1"
 	;;
diff --git a/target/linux/ramips/mt7621/base-files/etc/board.d/02_network b/target/linux/ramips/mt7621/base-files/etc/board.d/02_network
index 9e4f139a4c..5d49dad24a 100644
--- a/target/linux/ramips/mt7621/base-files/etc/board.d/02_network
+++ b/target/linux/ramips/mt7621/base-files/etc/board.d/02_network
@@ -141,6 +141,9 @@ ramips_setup_interfaces()
 	mqmaker,witi)
 		ucidef_set_interfaces_lan_wan "lan1 lan2 lan3 lan4" "wan1 wan2"
 		;;
+	richard,mt7621-ig-router)
+		ucidef_set_interfaces_lan_wan "lan1 lan2" "wan"
+		;;
 	tozed,zlt-s12-pro)
 		ucidef_set_interface_lan "lan1 lan2 lan3 wan"
 		ucidef_set_interface "wwan" device "/dev/ttyUSB0" protocol "ncm"
-- 
